{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Email" ],

    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Error"
      }
    },

    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Email",
        "Args": {
          "fromEmail": "",
          "toEmail": "",
          "mailServer": "smtp.gmail.com",
          "port": 587,
          "networkCredentials": {
            "userName": "",
            "password": ""
          },
          "enableSsl": true,
          "mailSubject": "Student Project Alert: {Level}",
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "Timestamp: {Timestamp:yyyy-MM-dd HH:mm:ss}\nLevel: {Level}\nMessage: {Message}\n\nException Details:\n{Exception}"

        }
      }
    ]
  }
}